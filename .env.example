# Copy this file to .env.local and fill in real values.
# Every variable here is validated at startup by src/config/env.ts —
# the app refuses to boot if one is missing.

# Supabase project URL — Project Settings > API > Project URL
VITE_SUPABASE_URL=

# Supabase anonymous/public API key — Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=
