# Secrets for supabase/functions/ (Edge Functions). These are NOT
# frontend env vars — Vite never sees them, and they never go in the
# root .env.local. Set them for real with:
#   supabase secrets set --env-file supabase/functions/.env.local
# (copy this file to supabase/functions/.env.local, fill in real values;
# that copy is already covered by supabase/.gitignore — never commit it)
#
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically into every edge function by Supabase — do not
# set them here, and never move the service_role key anywhere else.

# Shared secret Kirvano sends back with every webhook call. Set the same
# value here and in Kirvano's webhook config ("Token" field) — see
# supabase/functions/kirvano-webhook/index.ts.
KIRVANO_WEBHOOK_SECRET=

# Fallback locale/country kirvano-webhook uses when the payload doesn't
# carry enough signal to infer one.
KIRVANO_DEFAULT_LOCALE=pt-BR
KIRVANO_DEFAULT_COUNTRY=BR

# Base URL of the deployed app — used to build the "set your password" /
# "reset password" links included in emails.
APP_URL=https://app.olhardetutor.com

# Email delivery, pluggable — see supabase/functions/_shared/email/provider.ts.
# EMAIL_PROVIDER=log (the default when unset) just logs instead of
# sending, which is safe for local/dev before a real key exists.
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
