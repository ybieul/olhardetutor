# ─────────────────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets
# ─────────────────────────────────────────────────────────────────────────────
# These are server-side secrets. Vite never sees them, and they never go in
# the root .env.local.
#
# Set real values with:
#   supabase secrets set --env-file supabase/functions/.env.local
# (copy this file to supabase/functions/.env.local and fill in real values;
#  that file is already in supabase/.gitignore — never commit it)
#
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into every Edge Function by Supabase — do not set them here.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Kirvano webhook ─────────────────────────────────────────────────────────
# Shared secret Kirvano sends with every webhook call. Set the same value
# here and in Kirvano's webhook configuration ("Token" field).
KIRVANO_WEBHOOK_SECRET=

# Fallback locale/country when the Kirvano payload lacks enough signal.
KIRVANO_DEFAULT_LOCALE=pt-BR
KIRVANO_DEFAULT_COUNTRY=BR

# ─── App URL ─────────────────────────────────────────────────────────────────
# Base URL of the deployed app — used to build password-reset and invite links
# in outgoing emails. No trailing slash.
APP_URL=https://app.olhardetutor.com

# ─── Email delivery ──────────────────────────────────────────────────────────
# EMAIL_PROVIDER=log  →  logs instead of sending (safe for dev/staging)
# EMAIL_PROVIDER=resend  →  sends via Resend (requires RESEND_API_KEY)
EMAIL_PROVIDER=log

# Resend API key — required only when EMAIL_PROVIDER=resend
# Create at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address registered in your Resend domain
EMAIL_FROM_ADDRESS=

# ─── Push notifications / Web Push VAPID ─────────────────────────────────────
# Generate a key pair once:
#   npx web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY must match VITE_VAPID_PUBLIC_KEY in the frontend .env.local.
# VAPID_PRIVATE_KEY is server-only — never put it in .env.local or the repo.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact address included in the VAPID JWT — required by RFC 8292.
# Use mailto: or https: format.
VAPID_MAILTO=mailto:admin@olhardetutor.com.br

# ─── Notification cron authentication ────────────────────────────────────────
# Shared secret that secures the cron → Edge Function call.
# The Vercel cron API route (api/notifications/*.js) sends this as:
#   Authorization: Bearer <NOTIFICATION_SECRET>
# The send-notification Edge Function verifies it.
# Use a long random string (e.g. openssl rand -hex 32).
# Set this BOTH here (Supabase secret) AND in the Vercel dashboard.
NOTIFICATION_SECRET=
